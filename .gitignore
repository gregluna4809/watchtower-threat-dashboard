# Watchtower repository ignore rules

# Java / Spring Boot / Maven
target/
backend/target/

*.class
*.jar
*.war
*.ear

.mvn/wrapper/maven-wrapper.jar

# Node / React / Vite
node_modules/
coverage/

frontend/node_modules/
frontend/dist/
frontend/build/
frontend/coverage/
frontend/.vite/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets
.env
.env.*
*.env
!.env.example

backend/src/main/resources/application-local.yml
backend/src/main/resources/application-dev.yml
backend/src/main/resources/application-prod.yml
!backend/src/main/resources/application-example.yml

secrets/
keys/

*.pem
*.key
*.p12
*.jks

# Database / local storage
*.db
*.sqlite
*.sqlite3

postgres-data/
pgdata/
watchtower_pgdata/
docker-data/

# GeoIP / threat intel data
*.mmdb

# Logs / temp files
logs/
*.log

tmp/
temp/
.cache/

# IDE / editor
.idea/
*.iml

.vscode/

.project
.classpath
.settings/

# Operating system files
.DS_Store
Thumbs.db
desktop.ini

*.tmp
~$*

# Docker local state
.docker/

# Test / report output
reports/
surefire-reports/
backend/target/surefire-reports/

# Local-only workflow files
Prompts/
CLAUDE.md
AGENTS.md

# Optional local files
local/
sandbox/
experiments/
