# Watchtower local development placeholders

POSTGRES_DB=<database_name>
POSTGRES_USER=<database_user>
POSTGRES_PASSWORD=<database_password>

SPRING_DATASOURCE_URL=jdbc:postgresql://<postgres_host>:<postgres_port>/<database_name>
SPRING_DATASOURCE_USERNAME=<database_user>
SPRING_DATASOURCE_PASSWORD=<database_password>

ABUSEIPDB_API_KEY=<optional_abuseipdb_api_key>

# Production docker-compose.prod.yml
WATCHTOWER_DB_NAME=watchtower
WATCHTOWER_DB_USER=watchtower
WATCHTOWER_DB_PASSWORD=<required_production_database_password>
WATCHTOWER_OBSERVER_TOKEN=<required_when_host_observer_profile_is_enabled>
WATCHTOWER_OBSERVER_INTERVAL_SECONDS=3
